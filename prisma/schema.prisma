generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Store {
  id          String        @id @default(cuid())
  name        String
  address     String        @default("")
  city        String        @default("")
  state       String        @default("")
  zip_code    String        @default("")
  block       String?
  status      String        @default("Active") // 'Active' or 'Inactive'
  max_members Int           @default(3)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  members     StoreMember[]
  reports     DailyReport[]
  expenses    StoreExpense[]

  @@map("stores")
}

model User {
  id                 String        @id @default(cuid())
  name               String
  email              String        @unique
  password_hash      String
  role               String        @default("Staff") // 'Admin' or 'Staff'
  status             String        @default("Active") // 'Active' or 'Inactive'
  base_salary        Decimal       @default(0) @db.Decimal(10, 2)
  reset_token        String?
  reset_token_expiry DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  storeMembers       StoreMember[]
  reports            DailyReport[]
  edit_logs          EditLog[]
  system_logs        SystemLog[]
  payroll_records    PayrollRecord[]
  store_expenses     StoreExpense[]
  assigned_reports   DailyReport[] @relation("ReportAssignees")

  @@map("users")
}

model StoreMember {
  id          String   @id @default(cuid())
  store_id    String
  user_id     String
  is_reporter Boolean  @default(false)
  status      String   @default("Active") // 'Active' or 'Inactive'
  assigned_at DateTime @default(now())

  store       Store    @relation(fields: [store_id], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([store_id, user_id])
  @@map("store_members")
}

model DailyReport {
  id                   String   @id @default(cuid())
  store_id             String
  report_date          DateTime @db.Date
  submitted_by_user_id String
  cash_amount          Decimal  @db.Decimal(10, 2)
  card_amount          Decimal  @db.Decimal(10, 2)
  expenses_amount      Decimal  @default(0) @db.Decimal(10, 2)
  payouts_amount       Decimal  @default(0) @db.Decimal(10, 2)
  total_amount         Decimal  @db.Decimal(10, 2)
  time_in              String?  // Ex: "10:00 AM"
  time_out             String?  // Ex: "08:00 PM"
  notes                String?
  status               String   @default("Submitted") // 'Submitted', 'Verified', 'CorrectionRequested'
  staff_edit_count     Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  store                Store         @relation(fields: [store_id], references: [id])
  submitted_by         User          @relation(fields: [submitted_by_user_id], references: [id])
  images               ReportImage[]
  edit_logs            EditLog[]
  assignees            User[]        @relation("ReportAssignees")

  @@unique([store_id, report_date])
  @@map("daily_reports")
}

model ReportImage {
  id          String   @id @default(cuid())
  report_id   String
  image_url   String
  createdAt   DateTime @default(now())

  report      DailyReport @relation(fields: [report_id], references: [id], onDelete: Cascade)

  @@map("report_images")
}

model EditLog {
  id          String   @id @default(cuid())
  report_id   String
  user_id     String   // The user (admin or staff) who made the edit
  changes     String   // JSON payload of what changed {"cash": {"old": 100, "new": 150}}
  createdAt   DateTime @default(now())

  report      DailyReport @relation(fields: [report_id], references: [id], onDelete: Cascade)
  // user object relation is optional, we'll join by user_id to keep it simple but let's add it for consistency
  user        User        @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("edit_logs")
}

model SystemLog {
  id          String   @id @default(cuid())
  user_id     String   // Who did it
  action      String   // e.g. "USER_LOGIN", "STORE_CREATE", "REPORT_EDIT", "USER_DELETE"
  entity      String   // e.g. "User", "Store", "DailyReport"
  entity_id   String   // ID of the target object
  details     String?  // JSON stringified payload of changes or context
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("system_logs")
}

model PayrollRecord {
  id          String   @id @default(cuid())
  user_id     String
  month_year  String   // "YYYY-MM"
  base_salary Decimal  @db.Decimal(10, 2)
  total_paid  Decimal  @default(0) @db.Decimal(10, 2)
  status      String   @default("Pending") // 'Pending', 'Partial', 'Paid'
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  payments    PayrollPayment[]

  @@unique([user_id, month_year])
  @@map("payroll_records")
}

model PayrollPayment {
  id          String   @id @default(cuid())
  record_id   String
  amount      Decimal  @db.Decimal(10, 2)
  payment_date DateTime @db.Date
  notes       String?
  createdAt   DateTime @default(now())

  record      PayrollRecord @relation(fields: [record_id], references: [id], onDelete: Cascade)

  @@map("payroll_payments")
}

model StoreExpense {
  id          String   @id @default(cuid())
  store_id    String
  user_id     String   // Admin who logged it
  category    String   // e.g., 'Inventory', 'Rent', 'Utilities', 'Maintenance', 'Other'
  amount      Decimal  @db.Decimal(10, 2)
  expense_date DateTime @db.Date
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  store       Store    @relation(fields: [store_id], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [user_id], references: [id])

  @@map("store_expenses")
}

